# ── Appearance ──
theme = light:Catppuccin Latte,dark:Catppuccin Mocha
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 14
font-thicken = true
adjust-cell-height = 12%
background-opacity = 0.92
background-blur = 20
window-padding-x = 12
window-padding-y = 8
window-padding-balance = true
macos-titlebar-style = tabs
macos-option-as-alt = true

# ── Behavior / QoL ──
copy-on-select = clipboard
confirm-close-surface = true
window-save-state = always
mouse-hide-while-typing = true
scrollback-limit = 100000000
shell-integration-features = cursor,sudo,title
clipboard-read = allow
clipboard-write = allow

# ── Quick Terminal ──
quick-terminal-position = top
quick-terminal-animation-duration = 0.12
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# ── Splits native ──
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_surface
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
keybind = cmd+ctrl+left=resize_split:left,40
keybind = cmd+ctrl+right=resize_split:right,40
keybind = cmd+enter=toggle_split_zoom

# ── QoL keybinds ──
keybind = cmd+shift+r=reload_config
keybind = cmd+k=clear_screen
