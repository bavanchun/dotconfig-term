# Brew shellenv first so /opt/homebrew/bin is on PATH for non-login shells
# (e.g. wezterm), which don't get path_helper via /etc/zprofile.
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# fastfetch on terminal open — must run BEFORE p10k instant prompt to avoid
# "console output during zsh initialization" warning. Skip inside tmux.
[[ $- == *i* && -z $TMUX ]] && command -v fastfetch >/dev/null && fastfetch

# Powerlevel10k instant prompt — must be near top, before any output
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export NVM_DIR="$HOME/.config/nvm"
export PATH="$HOME/.local/bin:/usr/local/bin:/Applications/Visual Studio Code.app/Contents/Resources/app/bin:$PATH"

# Flutter / Android / JDK toolchain
export JAVA_HOME="/opt/homebrew/opt/openjdk@21"
export ANDROID_HOME="/opt/homebrew/share/android-commandlinetools"
export PATH="$JAVA_HOME/bin:$ANDROID_HOME/platform-tools:$ANDROID_HOME/emulator:$PATH"

export DOCKER_HOST="unix://${HOME}/.colima/default/docker.sock"

if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    . "$NVM_DIR/nvm.sh" --no-use
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

    __nvm_use_default() {
        unfunction node npm npx corepack codex gemini 2>/dev/null
        nvm use --silent default >/dev/null 2>&1 || nvm use --silent node >/dev/null
    }

    node() { __nvm_use_default; command node "$@"; }
    npm() { __nvm_use_default; command npm "$@"; }
    npx() { __nvm_use_default; command npx "$@"; }
    corepack() { __nvm_use_default; command corepack "$@"; }
    codex() { __nvm_use_default; command codex "$@"; }
    gemini() { __nvm_use_default; command gemini "$@"; }
    ck() { __nvm_use_default; command ck "$@"; }
fi

#export claude="/home/vchun/.local/bin/claude"

### Added by Zinit's installer
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager (%F{33}zdharma-continuum/zinit%F{220})...%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33} %F{34}Installation successful.%f%b" || \
        print -P "%F{160} The clone has failed.%f%b"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# Load a few important annexes, without Turbo
# (this is currently required for annexes)
zinit light-mode for \
    zdharma-continuum/zinit-annex-as-monitor \
    zdharma-continuum/zinit-annex-bin-gem-node \
    zdharma-continuum/zinit-annex-patch-dl \
    zdharma-continuum/zinit-annex-rust

# Powerlevel10k prompt theme
zinit ice depth=1
zinit light romkatv/powerlevel10k

# Plugins
zinit light zsh-users/zsh-autosuggestions
zinit light zdharma-continuum/fast-syntax-highlighting   # replaces zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit snippet OMZ::plugins/git/git.plugin.zsh
zinit snippet OMZ::plugins/alias-finder/alias-finder.plugin.zsh
zinit ice atclone'local base="https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/plugins/tmux"; curl -sL "$base/tmux.extra.conf" -o tmux.extra.conf; curl -sL "$base/tmux.only.conf" -o tmux.only.conf' atpull'%atclone'
zinit snippet OMZ::plugins/tmux/tmux.plugin.zsh
zinit light z-shell/zsh-eza
zinit light djui/alias-tips

# Initialize completion system (must run after all fpath additions, before fzf-tab)
autoload -Uz compinit && compinit

# fzf-tab: replace default completion with fzf (load after compinit, before other completion plugins)
zinit light Aloxaf/fzf-tab

# fzf-tab: show alias/command expansion in preview pane
# Preview reads from cached alias file (subshell can't access runtime aliases)
zstyle ':fzf-tab:complete:-command-:*' fzf-preview \
  'grep -m1 "^$word=" ~/.cache/zsh-aliases.txt 2>/dev/null | sed "s/^[^=]*=//" || which "$word" 2>/dev/null || echo "$word"'
zstyle ':fzf-tab:*' fzf-flags '--height=50%' '--preview-window=right:40%:wrap'

# History substring search: type partial command then ↑/↓ to search history
zinit light zsh-users/zsh-history-substring-search
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# forgit: interactive git commands powered by fzf (ga, glo, gd, gcb, ...)
zinit light wfxr/forgit

# zoxide: smarter cd with frecency — replaces `cd` (real paths still work, `cdi` = interactive)
eval "$(zoxide init zsh --cmd cd)"

# Tiện ích hàng ngày
zinit snippet OMZ::plugins/sudo/sudo.plugin.zsh
zinit snippet OMZ::plugins/colored-man-pages/colored-man-pages.plugin.zsh
zinit snippet OMZ::plugins/extract/extract.plugin.zsh

# Docker, Docker Compose, and Kubernetes — via OMZ plugins
zinit snippet OMZ::plugins/docker/docker.plugin.zsh
zinit snippet OMZ::plugins/docker-compose/docker-compose.plugin.zsh
zinit snippet OMZ::plugins/kubectl/kubectl.plugin.zsh

# Java / Spring Boot
zinit snippet OMZ::plugins/mvn/mvn.plugin.zsh
zinit snippet OMZ::plugins/sdk/sdk.plugin.zsh

# Cache all aliases to file so fzf-tab preview can read them in subshell
alias > ~/.cache/zsh-aliases.txt 2>/dev/null

