eval "$(starship init zsh)"

export NVM_DIR="$HOME/.config/nvm"
export PATH="$HOME/.local/bin:$PATH"
if [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    . "$NVM_DIR/nvm.sh" --no-use
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

    __nvm_use_default() {
        unfunction node npm npx corepack codex gemini 2>/dev/null
        nvm use --silent default >/dev/null 2>&1 || nvm use --silent node >/dev/null
    }

    node() { __nvm_use_default; command node "$@"; }
    npm() { __nvm_use_default; command npm "$@"; }
    npx() { __nvm_use_default; command npx "$@"; }
    corepack() { __nvm_use_default; command corepack "$@"; }
    codex() { __nvm_use_default; command codex "$@"; }
    gemini() { __nvm_use_default; command gemini "$@"; }
fi

#export claude="/home/vchun/.local/bin/claude"

### Added by Zinit's installer
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager (%F{33}zdharma-continuum/zinit%F{220})...%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33} %F{34}Installation successful.%f%b" || \
        print -P "%F{160} The clone has failed.%f%b"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# Load a few important annexes, without Turbo
# (this is currently required for annexes)
zinit light-mode for \
    zdharma-continuum/zinit-annex-as-monitor \
    zdharma-continuum/zinit-annex-bin-gem-node \
    zdharma-continuum/zinit-annex-patch-dl \
    zdharma-continuum/zinit-annex-rust

# Plugins
zinit light zsh-users/zsh-autosuggestions
zinit light zdharma-continuum/fast-syntax-highlighting   # replaces zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit snippet OMZ::plugins/git/git.plugin.zsh
zinit snippet OMZ::plugins/alias-finder/alias-finder.plugin.zsh
zinit ice atclone'local base="https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/plugins/tmux"; curl -sL "$base/tmux.extra.conf" -o tmux.extra.conf; curl -sL "$base/tmux.only.conf" -o tmux.only.conf' atpull'%atclone'
zinit snippet OMZ::plugins/tmux/tmux.plugin.zsh
zinit light z-shell/zsh-eza
zinit light djui/alias-tips

# fzf-tab: replace default completion with fzf (load after compinit, before other completion plugins)
zinit light Aloxaf/fzf-tab

# History substring search: type partial command then ↑/↓ to search history
zinit light zsh-users/zsh-history-substring-search
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# forgit: interactive git commands powered by fzf (ga, glo, gd, gcb, ...)
zinit light wfxr/forgit

# zoxide: smarter cd with frecency (z <partial-path>)
eval "$(zoxide init zsh)"

### End of Zinit's installer chunk

# Run Codex with separate local state per account so two accounts can stay logged in at once.
alias codex1='CODEX_HOME=$HOME/.codex-account-1 codex'
alias codex2='CODEX_HOME=$HOME/.codex-account-2 codex'
