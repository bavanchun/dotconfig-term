#!/usr/bin/env bash
# packages hash: {{ .packages | toJson | sha256sum }}
set -euo pipefail

{{ if eq .chezmoi.os "linux" -}}
{{   if eq .chezmoi.osRelease.id "ubuntu" -}}
sudo apt update
sudo apt install -y \
  {{ range .packages.common }}{{ . }} {{ end }}\
  {{ range .packages.apt }}{{ . }} {{ end }}

# starship — not in Ubuntu apt, install via script
if ! command -v starship >/dev/null 2>&1; then
  curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# wezterm — install via flatpak or .deb
if ! command -v wezterm >/dev/null 2>&1; then
  flatpak install -y flathub org.wezfurlong.wezterm 2>/dev/null || \
    echo "wezterm: install manually from https://wezfurlong.org/wezterm/install/linux.html"
fi

{{   else if eq .chezmoi.osRelease.id "arch" -}}
sudo pacman -S --needed --noconfirm \
  {{ range .packages.common }}{{ . }} {{ end }}\
  {{ range .packages.pacman }}{{ . }} {{ end }}

{{   else -}}
echo "Warning: unsupported Linux distribution {{ .chezmoi.osRelease.id }}, skipping package install"
{{   end -}}
{{ else if eq .chezmoi.os "darwin" -}}
if ! command -v brew >/dev/null 2>&1; then
  echo "Warning: Homebrew not found, skipping package install"
  echo "Install Homebrew first: https://brew.sh"
  exit 0
fi

if ! xcode-select -p >/dev/null 2>&1; then
  echo "Warning: Xcode Command Line Tools not found"
  echo "Run: xcode-select --install"
  echo "Neovim native plugin builds such as telescope-fzf-native need make/clang."
fi

brew install \
  {{ range .packages.common }}{{ . }} {{ end }}\
  {{ range .packages.brew }}{{ . }} {{ end }}

brew install --cask \
  {{ range .packages.brew_cask }}{{ . }} {{ end }}

{{ else -}}
echo "Warning: unsupported OS {{ .chezmoi.os }}, skipping package install"
{{ end -}}
